use axum::Router;
use firefly_web::FireflyServer;

#[tokio::main]
async fn main() -> Result<(), Box<dyn std::error::Error>> {
    let router = Router::new().merge(controllers::routes());
    FireflyServer::new(router).bind("0.0.0.0:8080").serve().await?;
    Ok(())
}
