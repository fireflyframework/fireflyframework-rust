//! {{ names.human }} saga orchestration.

use firefly_orchestration::{Outcome, Saga, SagaFailure, Step};

/// Build the `{{ names.kebab }}` saga: a multi-step orchestration where each
/// forward step has a compensating action that rolls it back if a later step
/// fails.
///
/// Run it with `build_{{ names.snake }}_saga().run().await`.
pub fn build_{{ names.snake }}_saga() -> Saga {
    Saga::new("{{ names.kebab }}").step(
        Step::new("reserve", || async {
            // Perform the forward action (e.g. reserve funds / inventory).
            Ok(())
        })
        .with_compensation(|| async {
            // Undo the forward action if a downstream step fails.
            Ok(())
        }),
    )
}

/// Convenience: build and run the saga, returning its terminal [`Outcome`].
pub async fn run_{{ names.snake }}_saga() -> Result<Outcome, SagaFailure> {
    build_{{ names.snake }}_saga().run().await
}
