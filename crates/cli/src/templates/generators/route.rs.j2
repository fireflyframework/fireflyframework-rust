//! {{ names.human }} route mappings.

use axum::{routing::get, Router};

/// Mount the `{{ names.kebab }}` routes onto an Axum [`Router`].
///
/// REST base path: `/{{ names.kebab_plural }}`.
pub fn {{ names.snake }}_routes() -> Router {
