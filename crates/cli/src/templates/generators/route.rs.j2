        .route("/{{ names.kebab_plural }}", get(list_{{ names.snake_plural }}))
        .route("/{{ names.kebab_plural }}/:id", get(get_{{ names.snake }}))
}

/// `GET /{{ names.kebab_plural }}` — list {{ names.human_plural }}.
